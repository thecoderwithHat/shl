# Optional: enables the OpenRouter + LangChain path
OPENROUTER_API_KEY=

# Defaults to meta-llama/llama-3-8b-instruct
OPENROUTER_MODEL=meta-llama/llama-3-8b-instruct

# Set to 1 to enable the optional LLM path; leave unset or 0 for deterministic mode
ENABLE_LLM=0

# Maximum number of recommendations returned in a response.
MAX_RECOMMENDATIONS=10

# Per-call timeout budget in seconds for the optional OpenRouter request.
OPENROUTER_TIMEOUT=25

# When loading a persisted FAISS index, langchain requires explicit opt-in to pickle deserialization.
# Set to 1 to allow loading a locally created index. Only enable if you trust the index files.
FAISS_ALLOW_DANGEROUS_DESERIALIZATION=1

# Path where the FAISS vector index will be persisted. Can be relative or absolute.
# If not set, defaults to ./faiss_index in the repository root.
FAISS_INDEX_PATH=./faiss_index

# Optional: control logging verbosity for shl.recommender (DEBUG/INFO/WARNING)
#LOG_LEVEL=INFO
